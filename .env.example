# Copy this file to .env and fill in your credentials
IQ_EMAIL=your@email.com
IQ_PASSWORD=yourpassword
IQ_ACCOUNT_TYPE=PRACTICE   # PRACTICE or REAL

ASSET=EURUSD
TRADE_AMOUNT=1.0            # USD per trade
TRADE_DURATION=1            # minutes (1, 2, 3, 5)
CANDLE_TIMEFRAME=60         # seconds per candle

MODEL_DIR=./knowledge       # where the AI brain is saved
DAILY_LOSS_LIMIT=20.0       # stop trading if daily loss exceeds this (USD)
